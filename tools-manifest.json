    {
      "name": "networks_create",
      "description": "Create a network/VLAN. Pass the full network object as --body-json or individual fields. Required: name. Optional: purpose, vlan_enabled, vlan (plus 5 more).",
      "method": "POST",
      "path": "/api/s/__SITE__/rest/networkconf",
      "params": [
        {
          "name": "name",
          "type": "string",
          "location": "body",
          "description": "Network name",
          "required": true
        },
        {
          "name": "purpose",
          "type": "string",
          "location": "body",
          "description": "corporate | guest | vlan-only | wan"
        },
        {
          "name": "vlan_enabled",
          "type": "bool",
          "location": "body",
          "description": "Enable VLAN tagging"
        },
        {
          "name": "vlan",
          "type": "string",
          "location": "body",
          "description": "VLAN id"
        },
        {
          "name": "ip_subnet",
          "type": "string",
          "location": "body",
          "description": "Gateway/subnet in CIDR (e.g. 192.168.20.1/24)"
        },
        {
          "name": "enabled",
          "type": "bool",
          "location": "body",
          "description": "Whether the network is enabled"
        },
        {
          "name": "dhcpd_enabled",
          "type": "bool",
          "location": "body",
          "description": "Enable the DHCP server"
        },
        {
          "name": "dhcpd_start",
          "type": "string",
          "location": "body",
          "description": "DHCP pool start IP"
        },
        {
          "name": "dhcpd_stop",
          "type": "string",
          "location": "body",
          "description": "DHCP pool end IP"
        }
      ]
    },
