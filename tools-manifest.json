{
  "api_name": "unifi-network",
  "base_url": "https://192.168.1.1",
  "description": "UniFi Network controller CLI — devices, clients, WiFi, firewall, routing, VPN, DNS, DPI, stats and events over one static binary with a local SQLite mirror",
  "mcp_ready": "full",
  "http_transport": "standard",
  "mcp": {
    "endpoint_tools": "hidden",
    "orchestration": "code"
  },
  "auth": {
    "type": "api_key",
    "header": "X-API-KEY",
    "format": "{UNIFI_API_KEY}",
    "in": "header",
    "env_vars": [
      "UNIFI_API_KEY"
    ],
    "env_var_specs": [
      {
        "name": "UNIFI_API_KEY",
        "kind": "per_call",
        "required": true,
        "sensitive": true,
        "inferred": true
      }
    ]
  },
  "required_headers": [],
  "tools": [
    {
      "name": "acl-rules_create",
      "description": "Create a MAC ACL rule. Provide the rule object via --body-json. Required: name, action.",
      "method": "POST",
      "path": "/v2/api/site/__SITE__/acl-rules",
      "params": [
        {
          "name": "name",
          "type": "string",
          "location": "body",
          "description": "Rule name",
          "required": true
        },
        {
          "name": "action",
          "type": "string",
          "location": "body",
          "description": "ALLOW | BLOCK",
          "required": true
        }
      ]
    },
    {
      "name": "acl-rules_delete",
      "description": "Delete a MAC ACL rule by id. Required: id. Destructive.",
      "method": "DELETE",
      "path": "/v2/api/site/__SITE__/acl-rules/{id}",
      "params": [
        {
          "name": "id",
          "type": "string",
          "location": "path",
          "description": "ACL rule _id",
          "required": true
        }
      ]
    },
    {
      "name": "acl-rules_list",
      "description": "List MAC ACL rules (Policy Engine) for L2 access control within a VLAN.",
      "method": "GET",
      "path": "/v2/api/site/__SITE__/acl-rules",
      "params": []
    },
    {
      "name": "acl-rules_update",
      "description": "Update a MAC ACL rule by id. Required: id.",
      "method": "PUT",
      "path": "/v2/api/site/__SITE__/acl-rules/{id}",
      "params": [
        {
          "name": "id",
          "type": "string",
          "location": "path",
          "description": "ACL rule _id",
          "required": true
        }
      ]
    },
    {
