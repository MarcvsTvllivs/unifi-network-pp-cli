    {
      "name": "dns-records_create",
      "description": "Create a static DNS record. Required: key, value, record_type. Optional: enabled, ttl.",
      "method": "POST",
      "path": "/v2/api/site/__SITE__/static-dns",
      "params": [
        {
          "name": "key",
          "type": "string",
          "location": "body",
          "description": "Hostname (e.g. myhost.example.com)",
          "required": true
        },
        {
          "name": "value",
          "type": "string",
          "location": "body",
          "description": "Target IP or hostname",
          "required": true
        },
        {
          "name": "record_type",
          "type": "string",
          "location": "body",
          "description": "A | AAAA | CNAME | MX | TXT | SRV",
          "required": true
        },
        {
          "name": "enabled",
          "type": "bool",
          "location": "body",
          "description": "Whether the record is enabled"
        },
        {
          "name": "ttl",
          "type": "int",
          "location": "body",
          "description": "TTL in seconds (0 = default 300s)"
        }
      ]
    },
    {
      "name": "dns-records_delete",
      "description": "Delete a static DNS record by id. Required: id. Destructive.",
      "method": "DELETE",
      "path": "/v2/api/site/__SITE__/static-dns/{id}",
      "params": [
        {
          "name": "id",
          "type": "string",
          "location": "path",
          "description": "DNS record _id",
          "required": true
        }
