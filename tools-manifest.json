      "method": "DELETE",
      "path": "/v2/api/site/__SITE__/network-members-group/{id}",
      "params": [
        {
          "name": "id",
          "type": "string",
          "location": "path",
          "description": "Client group _id",
          "required": true
        }
      ]
    },
    {
      "name": "client-groups_get",
