      "name": "client-groups_update",
      "description": "Update a client group by id. Required: id.",
      "method": "PUT",
      "path": "/v2/api/site/__SITE__/network-members-group/{id}",
      "params": [
        {
          "name": "id",
          "type": "string",
          "location": "path",
          "description": "Client group _id",
          "required": true
        }
      ]
    },
